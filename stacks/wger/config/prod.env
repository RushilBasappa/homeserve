# stacks/wger/config/prod.env — wger's environment, loaded via `env_file:` in compose.yaml.
#
# This is upstream wger-project/docker's config/prod.env, adapted for this lab. Loaded by the
# docker-compose CLI at deploy time (NOT a bind mount), so it's Komodo/git-clone safe — Komodo
# clones the full repo, and the CLI reads this file relative to the compose file. Re-sync against
# the pinned image's upstream prod.env when bumping wger/server (verify keys still match).
#
# SECRETS ARE NOT HERE: SECRET_KEY and POSTGRES_PASSWORD are injected via the compose `environment:`
# block from mise (${WGER_SECRET_KEY} / ${WGER_POSTGRES_PASSWORD}). JWT keys (PowerSync/mobile) and
# the PowerSync PS_* vars are omitted — that feature is out of scope.
#
# LAB OVERRIDES vs upstream defaults are marked  # <-- lab

# --- public origin / behind-proxy (Traefik terminates TLS) ---
SITE_URL=https://wger.ragnaforge.xyz                    # <-- lab
CSRF_TRUSTED_ORIGINS=https://wger.ragnaforge.xyz        # <-- lab (upstream ships this commented)
X_FORWARDED_PROTO_HEADER_SET=True                       # <-- lab (upstream ships this commented)
USE_X_FORWARDED_HOST=True                               # <-- lab (upstream ships this commented)

TIME_ZONE=Europe/Berlin
TZ=Europe/Berlin
WGER_INSTANCE=https://wger.de

# --- accounts / registration ---
ALLOW_REGISTRATION=False                                # <-- lab (upstream True) — bootstrap admin only
ALLOW_GUEST_USERS=False
ALLOW_UPLOAD_VIDEOS=True
MIN_ACCOUNT_AGE_TO_TRUST=21

# --- background sync (Celery). Exercise/ingredient metadata on; heavy image/video off for disk ---
SYNC_EXERCISES_CELERY=True
SYNC_EXERCISE_IMAGES_CELERY=False                       # <-- lab (upstream True) — disk-friendly
SYNC_EXERCISE_VIDEOS_CELERY=False                       # <-- lab (upstream True) — disk-friendly
SYNC_INGREDIENTS_CELERY=True
SYNC_INGREDIENTS_DUMP_URL=https://wger.de/media/ingredients/ingredients.jsonl.gz
DOWNLOAD_INGREDIENTS_FROM=WGER
CACHE_API_EXERCISES_CELERY=True
CACHE_API_EXERCISES_CELERY_FORCE_UPDATE=True
USE_CELERY=True
CELERY_BROKER=redis://cache:6379/2
CELERY_BACKEND=redis://cache:6379/2
CELERY_FLOWER_PASSWORD=adminadmin
CELERY_WORKER_CONCURRENCY=4

# --- database (host defaults to service `db`; PASSWORD injected via compose environment) ---
POSTGRES_USER=wger
POSTGRES_DB=wger
DJANGO_PERFORM_MIGRATIONS=True

# --- cache (django_redis — ALL four keys required together, else import_string("") crashes) ---
DJANGO_CACHE_BACKEND=django_redis.cache.RedisCache
DJANGO_CACHE_LOCATION=redis://cache:6379/1
DJANGO_CACHE_TIMEOUT=1296000
DJANGO_CACHE_CLIENT_CLASS=django_redis.client.DefaultClient

# --- brute-force lockout (django-axes; cache-backed) ---
AXES_ENABLED=True
AXES_FAILURE_LIMIT=10
AXES_COOLOFF_TIME=30
AXES_HANDLER=axes.handlers.cache.AxesCacheHandler
AXES_LOCKOUT_PARAMETERS=ip_address
AXES_IPWARE_PROXY_COUNT=1
AXES_IPWARE_META_PRECEDENCE_ORDER=HTTP_X_FORWARDED_FOR,REMOTE_ADDR

# --- server ---
DJANGO_DEBUG=False
WGER_USE_GUNICORN=True
EXERCISE_CACHE_TTL=2419200
WGER_PORT=8000
ACCESS_TOKEN_LIFETIME=10
REFRESH_TOKEN_LIFETIME=2880
AUTH_PROXY_HEADER=
AUTH_PROXY_TRUSTED_IPS=
AUTH_PROXY_CREATE_UNKNOWN_USER=False
AUTH_PROXY_USER_EMAIL_HEADER=
AUTH_PROXY_USER_NAME_HEADER=
LOG_LEVEL_PYTHON=INFO
USE_RECAPTCHA=False
DJANGO_CLEAR_STATIC_FIRST=False
DJANGO_COLLECTSTATIC_ON_STARTUP=True
FROM_EMAIL=wger Workout Manager <wger@example.com>
NUMBER_OF_PROXIES=1
GUNICORN_CMD_ARGS=--workers 3 --threads 2 --worker-class gthread --timeout 240
EXPOSE_PROMETHEUS_METRICS=False
