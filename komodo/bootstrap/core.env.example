# core.env.example — NON-SECRET Komodo Core configuration (research R7).
#
# Copy to `core.env` (which is gitignored by the `*.env` rule) before the first
# `make komodo-core`:
#
#     cp komodo/bootstrap/core.env.example komodo/bootstrap/core.env
#
# Real SECRETS (DB password, JWT/webhook secrets, passkey) do NOT belong here —
# they come from the gitignored `.mise.toml` via `mise exec` at bring-up. This
# file holds only non-sensitive knobs, so it is safe to track as an example.

# Public-facing base URL Core advertises (used in webhook URLs and links). This
# is the LAN address in Phase 2; it becomes the https domain in Phase 3.
KOMODO_HOST=http://10.0.0.70:9120

# UI title.
KOMODO_TITLE=Ragnaforge

# Database name inside MongoDB.
KOMODO_DATABASE_DB_NAME=komodo

# Built-in username/password auth (research R7). Enabled so the single admin can
# log in without an external identity provider.
KOMODO_LOCAL_AUTH=true

# Open registration. Leave `false` — create the single admin as the FIRST user,
# then keep this off so no one else can self-register (FR-009). If you need to
# create the very first user and the UI blocks it, flip to `true` only for that
# one bring-up, register, then set back to `false` and redeploy Core.
KOMODO_DISABLE_USER_REGISTRATION=true

# Make the first user to register an admin (convenience for the single-operator
# bootstrap). Harmless once registration is disabled.
KOMODO_ENABLE_NEW_USERS=false

# How often Core polls git repos (ResourceSyncs + Stacks) for new commits and
# refreshes its cached clone. Komodo's DEFAULT is 1-hr — too slow for an active
# repo (Core keeps serving an old commit long after a push). 5-min keeps Core's
# view fresh so a deploy shortly after `git push` uses the latest code. This only
# refreshes the VIEW — it does NOT auto-deploy (deploys stay deliberate: each
# stack's webhook_enabled=false, so you still trigger Deploy yourself). Since Core
# is LAN/Tailscale-only, GitHub push webhooks can't reach it — polling is the
# mechanism that keeps it current.
KOMODO_RESOURCE_POLL_INTERVAL=5-min
