# .mise.toml.example — placeholder secrets template
#
# Copy this file to `.mise.toml` and replace every placeholder with a real value:
#
#     cp .mise.toml.example .mise.toml
#
# `.mise.toml` is gitignored and MUST NEVER be committed. `mise` renders these
# into environment variables that Komodo injects into stacks. Every value below
# is an obvious placeholder — a leftover `changeme-` value means it wasn't filled.

[settings]
env_shell_expand = false

[env]
# Cloudflare API token — Let's Encrypt DNS-01 wildcard cert (*.ragnaforge.xyz)
# and Cloudflare DDNS (keeps vpn.ragnaforge.xyz on the current public IP).
# Scope: DNS edit on the ragnaforge.xyz zone. Used by: Traefik, Cloudflare DDNS.
CLOUDFLARE_API_TOKEN = "changeme-cloudflare-api-token"

# Commercial-VPN WireGuard egress credentials — used by Gluetun to route
# qBittorrent's traffic out through the VPN (killswitch on). Get these from your
# commercial VPN provider's WireGuard config.
WIREGUARD_PRIVATE_KEY = "changeme-wireguard-private-key"
WIREGUARD_ADDRESSES   = "changeme-wireguard-client-address"  # e.g. 10.64.0.2/32
# Optional, provider-dependent (uncomment/fill if your provider supplies them):
# WIREGUARD_PRESHARED_KEY = "changeme-wireguard-preshared-key"
# WIREGUARD_ENDPOINT_IP   = "changeme-wireguard-endpoint-ip"
# WIREGUARD_ENDPOINT_PORT = "51820"

# Tailscale auth key — personal remote-access VPN. Used to enroll nodes
# non-interactively. Generate at https://login.tailscale.com/admin/settings/keys
TAILSCALE_AUTHKEY = "changeme-tailscale-auth-key"

# Sudo (become) password for the admin user on the provisioned nodes. Ansible
# escalates to root via sudo; set this so `make provision` runs non-interactively
# instead of prompting. Sensitive — this is your login sudo password; it stays in
# the gitignored .mise.toml and is referenced by provision/group_vars/all.yml via
# an env lookup, so it never lands in a tracked file or a command line.
ANSIBLE_BECOME_PASSWORD = "changeme-sudo-password"

# --- Phase 2: Komodo orchestration (research R4, R7, R9) ---
# Komodo Core's own bootstrap secrets, rendered by mise into the environment at
# `make komodo-core` bring-up (never written into a tracked file). Generate each
# as a long random string, e.g. `openssl rand -hex 32`.
#
# MongoDB root password for Core's datastore (Dell). Used by: core.compose.yaml.
KOMODO_DB_PASSWORD    = "changeme-komodo-db-password"
# Signing secret for Komodo's incoming git webhooks (per-stack auto-deploy).
KOMODO_WEBHOOK_SECRET = "changeme-komodo-webhook-secret"
# Secret Komodo uses to sign the JWTs backing its login sessions.
KOMODO_JWT_SECRET     = "changeme-komodo-jwt-secret"
# Shared passkey authenticating Core → Periphery calls. The SAME value must be in
# .mise.toml on the Dell (Core) and on every node running Periphery. Used by:
# core.compose.yaml + periphery.compose.yaml.
KOMODO_PASSKEY        = "changeme-komodo-passkey"

# Demo stack secret for the Phase-2 secret-injection proof (US3). A throwaway
# value injected into the whoami test stack as ${WHOAMI_TEST_SECRET} to prove a
# secret reaches a container with no value in git. Safe to delete after Phase 2.
WHOAMI_TEST_SECRET    = "changeme-whoami-demo-secret"

# Komodo API key + secret for driving Core from the CLI/API (create under
# Settings -> Profile -> API Keys). Operational convenience — real values go in
# the gitignored .mise.toml, never here.
KOMODO_API_KEY        = "changeme-komodo-api-key"
KOMODO_API_SECRET     = "changeme-komodo-api-secret"

# --- Phase 3: Edge, DNS & TLS (research R6, R12) ---
# NOTE: CLOUDFLARE_API_TOKEN (above) is REUSED in Phase 3 for both Traefik's
# Let's Encrypt DNS-01 wildcard issuance AND Cloudflare DDNS — no new token needed
# (research R12). The two placeholders below are new to this phase.
#
# wg-easy admin password, as a BCRYPT HASH (not the plaintext). wg-easy reads it
# as PASSWORD_HASH so the admin secret is never stored in the clear. Generate with:
#   docker run --rm ghcr.io/wg-easy/wg-easy wgpw 'your-admin-password'
# (prints PASSWORD_HASH='...'; copy the hash between the quotes here). When pasting
# a bcrypt hash into a shell/compose env, remember $ must be escaped as $$ in the
# compose file — here in .mise.toml it is a plain string, so paste it verbatim.
WG_EASY_PASSWORD_HASH = "changeme-wg-easy-bcrypt-hash"

# AdGuard Home admin password. AdGuard stores its own bcrypt hash in AdGuardHome.yaml
# (set on first-run wizard or seeded from config); this value is the plaintext you
# log in with. Keep it here so the runbook can reference ${ADGUARD_ADMIN_PASSWORD}
# without printing a real value into a tracked file.
ADGUARD_ADMIN_PASSWORD = "changeme-adguard-admin-password"

# --- Phase 5: Media stack (ARR + Jellyfin/Plex) (research R2, R5, R10) ---
# NOTE: WIREGUARD_PRIVATE_KEY / WIREGUARD_ADDRESSES (above) are REUSED here for
# Gluetun → Proton VPN — Proton issues a standard WireGuard config, so no new VPN
# secret is added (research R2). Use a Proton plan WITH port forwarding.
#
# Deterministic servarr API keys — the linchpin of declarative plane-3 wiring
# (research R5). Each app's key is SET from these via env (RADARR__AUTH__APIKEY=...),
# so every key is known at deploy time and the wiring play is fully reproducible.
# Generate each as 32 hex chars:  openssl rand -hex 16
RADARR_API_KEY  = "changeme-radarr-api-key-32hex"
SONARR_API_KEY  = "changeme-sonarr-api-key-32hex"
PROWLARR_API_KEY = "changeme-prowlarr-api-key-32hex"
BAZARR_API_KEY  = "changeme-bazarr-api-key-32hex"

# qBittorrent Web UI password for HUMAN login. Gluetun's native port-sync reaches
# qBit via localhost-bypass (no creds), so this is only for the operator's UI login.
# Set it on first run (see docs/runbooks/phase5-media.md → qBittorrent first-run).
QBIT_WEBUI_PASSWORD = "changeme-qbittorrent-webui-password"

# Plex claim token — SHORT-LIVED (~4 min), from https://www.plex.tv/claim, used ONLY
# on Plex's first run to bind the server to your account (P2). After first run the
# server keeps its own token; this value is not needed again. Leave the placeholder
# until you deploy Plex, then paste a fresh claim-xxxx token and re-sync.
PLEX_CLAIM = "changeme-plex-claim-token"

# Shared media login — ONE username/password used across the media tools that need
# a login (Jellyfin admin; Seerr owner is created from the Jellyfin admin; can also
# be reused for qBittorrent / Jellystat). Consumed by the first-run Ansible plays
# (stacks/*/configure/*.yml), NOT by any container, so it is not forwarded to
# Periphery and needs no `make sync-secrets`. Choose a password YOU will type on
# TVs/phones (>=8 chars).
MEDIA_ADMIN_USER     = "changeme-media-admin-username"
MEDIA_ADMIN_PASSWORD = "changeme-media-admin-password"